<!doctype html>
<html lang="pt-BR">

<head>
  <!-- Charset e Viewport -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Título e Descrição -->
  <title>Cerquilho Imóveis - Explore Imóveis e Reduções de Preço</title>
  <meta name="description" content="Plataforma premium de busca e análise de imóveis em Cerquilho. Acompanhe reduções de preço, históricos de valor, análise de mercado e oportunidades em tempo real." />
  <meta name="keywords" content="imóveis cerquilho, casas cerquilho, apartamentos cerquilho, compra venda imóveis, redução preço imóvel, análise mercado imobiliário" />
  <meta name="author" content="Cerquilho Imóveis" />
  <meta name="theme-color" content="#050816" />
  
  <!-- Robots e Indexação -->
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="language" content="Portuguese" />
  <meta name="revisit-after" content="7 days" />
  
  <!-- Canonical URL -->
  <link rel="canonical" href="https://cerquilho-imoveis.com.br" />
  
  <!-- Open Graph / Social Media -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://cerquilho-imoveis.com.br" />
  <meta property="og:title" content="Cerquilho Imóveis - Explore Imóveis e Reduções de Preço" />
  <meta property="og:description" content="Plataforma premium de busca e análise de imóveis em Cerquilho. Acompanhe reduções de preço, históricos de valor, análise de mercado e oportunidades em tempo real." />
  <meta property="og:image" content="https://cerquilho-imoveis.com.br/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Cerquilho Imóveis" />
  <meta property="og:locale" content="pt_BR" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="https://cerquilho-imoveis.com.br" />
  <meta name="twitter:title" content="Cerquilho Imóveis - Explore Imóveis e Reduções de Preço" />
  <meta name="twitter:description" content="Plataforma premium de busca e análise de imóveis em Cerquilho. Acompanhe reduções de preço, históricos de valor, análise de mercado e oportunidades em tempo real." />
  <meta name="twitter:image" content="https://cerquilho-imoveis.com.br/og-image.png" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  
  <!-- Preconnect para Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="dns-prefetch" href="https://cdn.supabase.com" />
  
  <!-- JSON-LD Structured Data - Real Estate Agent -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    "name": "Cerquilho Imóveis",
    "url": "https://cerquilho-imoveis.com.br",
    "description": "Plataforma premium de busca e análise de imóveis em Cerquilho",
    "sameAs": [
      "https://www.facebook.com/cerquilhoimoveis",
      "https://www.instagram.com/cerquilhoimoveis",
      "https://www.linkedin.com/company/cerquilhoimoveis"
    ],
    "image": "https://cerquilho-imoveis.com.br/og-image.png",
    "areaServed": "Cerquilho, SP, Brasil",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+55-14-XXXX-XXXX",
      "contactType": "Customer Support"
    }
  }
  </script>
  
  <!-- JSON-LD Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Cerquilho Imóveis",
    "url": "https://cerquilho-imoveis.com.br",
    "logo": "https://cerquilho-imoveis.com.br/logo.png",
    "description": "Plataforma de busca e análise de imóveis com histórico de preços e reduções em tempo real",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+55-14-XXXX-XXXX",
      "contactType": "Customer Service"
    },
    "sameAs": [
      "https://www.facebook.com/cerquilhoimoveis",
      "https://www.instagram.com/cerquilhoimoveis"
    ]
  }
  </script>
  
  <!-- JSON-LD Local Business -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Cerquilho Imóveis",
    "image": "https://cerquilho-imoveis.com.br/og-image.png",
    "description": "Plataforma premium de busca e análise de imóveis em Cerquilho",
    "url": "https://cerquilho-imoveis.com.br",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cerquilho",
      "addressRegion": "SP",
      "postalCode": "XXXXX-XXX",
      "addressCountry": "BR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "-22.7236",
      "longitude": "-48.2000"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  }
  </script>
</head>

<body>
  <div id="root"></div>
  <script type="module" src="/src/main.tsx"></script>
</body>

</html>
